# ── Configuración BTU-UASLP ──────────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores

# Clave secreta de Flask (cámbiala en producción por una cadena aleatoria larga)
SECRET_KEY=cambia-esta-clave-en-produccion-btu-uaslp

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# Formato: mysql+pymysql://usuario:contrasena@host:puerto/nombre_base_de_datos
# Ejemplos:
#   Local:      mysql+pymysql://root:mi_password@localhost:3306/btu_uaslp
#   Produccion: mysql+pymysql://btu_user:mi_password@192.168.1.10:3306/btu_prod

MYSQL_URI=mysql+pymysql://root:tu_password@localhost:3306/btu_uaslp

# Si no defines MYSQL_URI, el sistema usa SQLite automáticamente (solo para desarrollo)
